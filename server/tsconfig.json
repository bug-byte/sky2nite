{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "shared/*": ["../shared/dist/*"]
    }
  },
  "references": [{ "path": "../shared" }],
  "files": ["src/test/jestOverrides.d.ts"],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
